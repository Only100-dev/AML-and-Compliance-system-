const QuarterlyReporting = lazy(() => import('@/components/ic-os/reporting/QuarterlyReporting').then(m => ({ default: m.QuarterlyReporting })));
const AMLSelfAssessment = lazy(() => import('@/components/ic-os/aml-assessment/AMLSelfAssessment').then(m => ({ default: m.AMLSelfAssessment })));
const AdvancedAnalytics = lazy(() => import('@/components/ic-os/analytics/AdvancedAnalytics').then(m => ({ default: m.AdvancedAnalytics })));
const ThemeSettings = lazy(() => import('@/components/ic-os/theme/ThemeSettings').then(m => ({ default: m.ThemeSettings })));
const SecurityDashboard = lazy(() => import('@/components/ic-os/security/SecurityDashboard').then(m => ({ default: m.SecurityDashboard })));
