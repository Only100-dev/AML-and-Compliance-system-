// Phase 5 — Post-login System Introduction / Welcome Tour (Part 6)
const SystemIntroduction = lazy(() => import('@/components/shared/SystemIntroduction').then(m => ({ default: m.SystemIntroduction })));

// UAT & Release modules
const UATHandoverPackage = lazy(() => import('@/components/ic-os/uat/UATHandoverPackage').then(m => ({ default: m.UATHandoverPackage })));
const IngestionEngine = lazy(() => import('@/components/ic-os/ingestion/IngestionEngine').then(m => ({ default: m.IngestionEngine })));

// v7.3.0-uat-hotfix-1 — P1 restoration: re-wire sections whose render cases were
// silently deleted by P2 commit ec4c992 (see RCA_P2_REGRESSION.md). Components
// already existed on disk; only the lazy imports + switch cases were missing.
const VendorManagement = lazy(() => import('@/components/ic-os/tprm/VendorManagement').then(m => ({ default: m.VendorManagement })));
const UploadBordereaux = lazy(() => import('@/components/ic-os/bordereaux/UploadBordereaux').then(m => ({ default: m.UploadBordereaux })));
