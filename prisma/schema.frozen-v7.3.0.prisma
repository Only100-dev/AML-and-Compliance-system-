  sha256Hash            String?
  jurisdiction          String    @default("CBUAE")
  riskLevel             String    @default("critical")
  confirmedById         String?
  confirmedAt           DateTime?

  // ── Traceability Foreign Keys (Pre-UAT Polish Fix #1) ──────────────────────
  // An auditor reviewing a frozen asset must be able to trace it directly
  // back to the specific Customer, Policy, and Case ID.
  // Ref: FDL 10/2025 Art. 11 (Record-Keeping); CBUAE Notice 3551/2021 S3.3
  customerId            String?   // FK → User.id (policyholder / entity owner)
  policyId              String?   // FK → Policy.id (insurance policy under freeze)
  caseId                String?   // FK → ComplianceCase.id (linked investigation case)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status])
  @@index([entityName])
  @@index([sanctionsList])
  @@index([freezeOrderDate])
  @@index([tfsReferenceNumber])
  @@index([customerId])
  @@index([policyId])
  @@index([caseId])
}

