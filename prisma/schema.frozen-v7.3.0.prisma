  scenario        ScenarioKnowledge @relation(fields: [scenarioId], references: [id])
  relevanceScore  Float    @default(0.0)           // 0.0-1.0 relevance score
  userFeedback    String?                          // "positive", "negative", null
  createdAt       DateTime @default(now())

  @@index([scenarioId, relevanceScore])
