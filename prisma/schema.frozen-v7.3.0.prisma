/// Scenario Knowledge entries for RAG-powered compliance assistant
/// Each entry represents one battle-tested operational scenario from Packs 1-11
model ScenarioKnowledge {
  id                String   @id @default(cuid())
  packNumber        Int                              // Pack 1-11
  category          String                           // e.g., "Takaful", "Sanctions", "BlackSwan", "GraphAnalytics"
  title             String   @unique                 // Unique scenario title
  scenarioText      String                           // Full scenario description
  complexity        String                           // Complexity analysis
