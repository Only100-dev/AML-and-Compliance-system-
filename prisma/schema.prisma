/// Scenario Knowledge entries for RAG-powered compliance assistant
/// Each entry represents one battle-tested operational scenario from Packs 1-11
model ScenarioKnowledge {
  id                String   @id @default(cuid())
  packNumber        Int                              // Pack 1-11
  category          String                           // e.g., "Takaful", "Sanctions", "BlackSwan", "GraphAnalytics"
  title             String   @unique                 // Unique scenario title
  scenarioText      String                           // Full scenario description
  complexity        String                           // Complexity analysis
  systemWorkflow    String                           // System workflow / response
  regulatoryAnchor  String                           // Regulatory references
  tags              String   @default("[]")          // JSON array: ["EarlySurrender", "GCC", "Layering"]
  riskLevel         String   @default("high")        // "low", "medium", "high", "critical"
  searchVector      String   @default("")            // Pre-computed searchable text (title + scenario + tags concatenated)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relationships for feedback & usage tracking
  chatReferences    ScenarioChatReference[]

  @@index([packNumber])
  @@index([category])
  @@index([riskLevel, isActive])
  @@index([isActive])
}

/// Tracks which scenarios were referenced in AI chat responses
/// Enables feedback loop and relevance scoring
model ScenarioChatReference {
  id              String   @id @default(cuid())
  chatSessionId   String                           // Link to AIChatSession
  chatMessageId   String?                          // Link to specific AIChatMessage
  scenarioId      String                           // Link to ScenarioKnowledge
  scenario        ScenarioKnowledge @relation(fields: [scenarioId], references: [id])
  relevanceScore  Float    @default(0.0)           // 0.0-1.0 relevance score
  userFeedback    String?                          // "positive", "negative", null
  createdAt       DateTime @default(now())

  @@index([scenarioId, relevanceScore])
  @@index([chatSessionId])
}

