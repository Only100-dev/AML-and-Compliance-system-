generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  name                   String
  role                   String    @default("compliance_officer")
  jurisdiction           String
  avatar                 String?
  isActive               Boolean   @default(true)
  passwordHash           String?   // P0-A Fix: bcrypt hashed password (replaces hardcoded demo passwords)
  dmlroDelegatedToId     String?
  dmlroDelegatedToName   String?
  dmlroDelegationActive  Boolean   @default(false)
  dmlroDelegationExpiry  DateTime?
  dmlroDelegationReason  String?
  sessionsRevokedAt      DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model RegulatoryCircular {
  id                String   @id @default(cuid())
  title             String
  regulator         String
  circularNumber    String
  effectiveDate     DateTime
  status            String   @default("ingested") // ingested | DRAFT | PUBLISHED | ARCHIVED | SUPERSEDED
  summary           String?
  affectedDepts     String?
  sourceUrl         String?
  // ── Phase F: Regulatory Circular Ingestion Engine (backward-compatible additions) ──
  issuingAuthority  String?  // CBUAE / UAE FIU / FATF / Insurance Board
  publicationDate   DateTime?
  documentUrl       String?  // local path or remote URL of source doc
  riskImpactLevel   String?  // LOW | MEDIUM | HIGH | CRITICAL
  ingestionMethod   String?  // MANUAL_UPLOAD | AUTO_SCRAPER
  version           Int      @default(1)
  supersedesId      String?  // FK to a prior RegulatoryCircular.id this one supersedes
  keyObligations    String?  // JSON array of obligation strings (committed)
  rawExtractedJson  String?  // full LLM extraction payload (auditability)
  documentHash      String?  @unique // SHA-256 of source document bytes (dedup)
  ingestionLogId    String?  // FK to IngestionLog.id
  committedAt       DateTime?
  committedById     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([riskImpactLevel])
  @@index([ingestionMethod])
  @@index([regulator])
  @@index([supersedesId])
}

// ── Phase F: Regulatory Circular Ingestion Engine ─────────────────────────────
// Source configuration for the automated crawler (Tier 2). The cron job that
// would invoke these sources is intentionally left DISABLED for V1/UAT; only
// the configuration surface and skeleton endpoints ship in this release.

model IngestionSource {
  id              String   @id @default(cuid())
  name            String   // "CBUAE Media Centre", "UAE FIU Newsroom", etc.
  baseUrl         String   // root URL of the source
  scraperType     String   @default("RSS") // RSS | HEADLESS | API
  cssSelectors    String?  // JSON: { title, date, body, link }
  crawlFrequency  String   @default("DAILY") // HOURLY | DAILY | WEEKLY
  isActive        Boolean  @default(false)
  lastCrawledAt   DateTime?
  lastCrawlStatus String?  // SUCCESS | ERROR | PAUSED
  lastErrorMessage String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
  @@index([scraperType])
}

// Individual obligation extracted from a circular (committed, searchable).
model ExtractedObligation {
  id              String   @id @default(cuid())
  circularId      String   // FK to RegulatoryCircular.id
  actionItem      String   // the obligation text
  affectedDept    String   // e.g. "Compliance", "Underwriting", "Claims", "Finance"
  deadlineDays    Int?     // days from effective date to comply
  status          String   @default("OPEN") // OPEN | IN_PROGRESS | REMEDIATED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([circularId])
  @@index([affectedDept])
  @@index([status])
}

// Append-only audit log of every ingestion event: upload, extraction,
// commit, scrape attempt. Stores the raw LLM JSON so auditors can reconstruct
// exactly what the model returned before any human editing.

model IngestionLog {
  id                String   @id @default(cuid())
  source            String   // MANUAL_UPLOAD | AUTO_SCRAPER:<sourceName>
  documentHash      String?  // SHA-256 of source bytes (dedup key)
  fileName          String?
  mimeType          String?
  fileSize          Int?
  status            String   @default("UPLOADED") // UPLOADED | EXTRACTED | COMMITTED | REJECTED | ERROR
  rawExtractedJson  String?  // full LLM extraction payload (auditability)
  reviewerId        String?
  reviewerName      String?
  reviewerNotes     String?
  errorMessage      String?
  circularId        String?  // FK to RegulatoryCircular.id (set on COMMITTED)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([source])
  @@index([documentHash])
  @@index([createdAt])
}

model GapAnalysis {
  id              String   @id @default(cuid())
  circularId      String
  missingClauses  String
  aiConfidence    Float    @default(0.0)
  status          String   @default("draft")
  approvedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AMLAlert {
  id              String   @id @default(cuid())
  caseId          String   @unique
  riskScore       Float    @default(0.0)
  riskLevel       String   @default("low")
  alertType       String
  description     String
  aiFlags         String?
  goAMLDraft      String?
  status          String   @default("new")
  assignedTo      String?
  createdBy       String?
  approvedBy      String?
  jurisdiction    String
  amount          Float    @default(0.0)
  policyNumber    String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, riskLevel])
  @@index([alertType, status])
  @@index([jurisdiction, status])
  @@index([assignedTo, status])
  @@index([createdAt])
  @@index([jurisdiction, createdAt])
}

model SanctionsException {
  id              String   @id @default(cuid())
  entityName      String
  riskDomain      String
  justification   String
  compensatingControls String?
  sunsetDate      DateTime
  approvedBy      String?
  status          String   @default("active")
  cbuaeNotified   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InspectionEvidence {
  id              String   @id @default(cuid())
  inspectionId    String
  fileName        String
  fileHash        String
  fileSize        Int      @default(0)
  fileType        String
  aiVerified      Boolean  @default(false)
  aiConfidence    Float    @default(0.0)
  aiVerificationDetail String?
  uploadedBy      String
  department      String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Claim {
  id              String   @id @default(cuid())
  claimNumber     String   @unique
  policyNumber    String
  claimType       String
  claimantName    String
  description     String
  amount          Float    @default(0.0)
  fraudScore      Float    @default(0.0)
  status          String   @default("submitted")
  priority        String   @default("normal")
  assignedAdjuster String?
  siuFlagged      Boolean  @default(false)
  jurisdiction    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([policyNumber, status])
  @@index([claimantName])
  @@index([siuFlagged, fraudScore])
  @@index([status, createdAt])
  @@index([assignedAdjuster, status])
  @@index([jurisdiction, status, createdAt])
  @@index([jurisdiction, createdAt])
}

model AuditLog {
  id              String   @id @default(cuid())
  userId          String
  action          String
  resource        String
  resourceId      String?
  details         String?
  aiConfidence    Float?
  sha256Hash      String?
  ipAddress       String?
  jurisdiction    String   @default("UNKNOWN")
  createdAt       DateTime @default(now())

  // P0-C Fix: WORM/Immutable Audit Chain — SHA-256 linked-list for tamper evidence
  prevHash        String?  // SHA-256 of the previous AuditLog entry (chain link)
  currentHash     String?  // SHA-256 of THIS entry (computed from all persisted fields + prevHash)
  chainIndex      Int      @default(0) // Monotonic sequence number for chain integrity verification
  isSealed        Boolean  @default(false) // Once sealed, entry cannot be modified (WORM)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([resource, createdAt])
  @@index([createdAt])
  @@index([userId, action, createdAt])
  @@index([jurisdiction, createdAt])
  @@index([jurisdiction, action, createdAt])
  @@index([chainIndex])
}

model KRIMetric {
  id              String   @id @default(cuid())
  name            String
  value           Float    @default(0.0)
  target          Float    @default(0.0)
  warning         Float?   // Phase 5: Warning threshold
  critical        Float?   // Phase 5: Critical threshold
  unit            String?  // Phase 5: %, tier, count, etc.
  trend           String   @default("stable")
  jurisdiction    String
  category        String
  updatedAt       DateTime @updatedAt

  @@index([jurisdiction, category])
  @@index([jurisdiction, name])
}

/// Phase 5: Compliance Gap Tracking & Remediation
/// PRINCIPLE C: Remediation is accountable — every gap has an owner, due date, and status.
/// PRINCIPLE D: Cross-region intelligence (systemic gap detection, anonymized).
model Gap {
  id                String    @id @default(cuid())
  jurisdictionId    String    // GCC alpha-2 code: AE, SA, BH, QA, OM, KW
  controlId         String?   // Link to specific control or obligation
  theme             String    // One of 9 scorecard themes
  title             String
  description       String
  severity          String    // Critical | High | Medium | Low | Observation
  status            String    @default("Open") // Open | In_Progress | Awaiting_Approval | Closed | Escalated
  detectedBy        String    @default("system") // system | user | audit | regulatory_change
  detectionTrigger  String?   // JSON metadata about what triggered this gap
  ownerId           String?   // FK to User.id
  ownerName         String?   // Denormalized for quick display
  ownerRole         String?   // Role of the assigned owner
  dueDate           DateTime?
  closedDate        DateTime?
  isSystemic        Boolean   @default(false) // Same gap found in multiple countries
  relatedGapIds     String?   // JSON array of Gap IDs in other jurisdictions
  evidence          String?   // JSON array of evidence objects
  remediationNotes  String?
  escalationLevel   Int       @default(0) // 0=none, 1=manager, 2=director, 3=C-suite
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([jurisdictionId, status])
  @@index([isSystemic])
  @@index([severity, status])
  @@index([ownerId, status])
  @@index([theme, jurisdictionId])
  @@index([dueDate])
}

/// Phase 5: Audit Scorecard — Compliance scoring by regulator and theme
/// PRINCIPLE B: Scoring is evidence-based. Gap rating (0-3) must have clear criteria.
model AuditScorecard {
  id              String   @id @default(cuid())
  jurisdictionId  String   // GCC alpha-2 code
  theme           String   // One of 9 scorecard themes
  regulator       String   // CBUAE, SAMA, CBB, QCB, CBOA, CBK
  gapRating       Int      @default(0) // 0=Compliant, 1=Minor, 2=Moderate, 3=Critical
  evidence        String?  // JSON: evidence supporting this rating
  lastAssessedBy  String?
  lastAssessedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([jurisdictionId, theme, regulator])
  @@index([jurisdictionId, theme])
  @@index([regulator])
  @@index([gapRating])
}

/// Phase 5: Regulatory Deadline Types — Multi-jurisdiction support
model RegulatoryDeadlineType {
  id              String   @id @default(cuid())
  code            String   @unique // e.g., CBUAE_SAR_FILING, SAMA_SAR_FILING
  name            String
  regulator       String
  jurisdictionId  String
  deadlineDays    Int
  deadlineUnit    String   @default("business_days") // business_days | calendar_days
  category        String   // SAR_FILING | CAPITAL_ADEQUACY | GOVERNANCE | etc.
  description     String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([jurisdictionId, category])
  @@index([regulator])
}

model Regulation {
  id                String   @id @default(cuid())
  title             String
  issuer            String
  category          String   @default("General")
  description       String?
  effectiveDate     DateTime
  nextReviewDate    DateTime?
  complianceStatus  String   @default("PENDING")
  assignedTo        String?
  priority          String   @default("normal")
  sourceUrl         String?
  jurisdiction      String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([jurisdiction, complianceStatus])
}

model Policy {
  id              String   @id @default(cuid())
  title           String
  policyNumber    String   @unique
  category        String
  version         String   @default("1.0")
  status          String   @default("draft")
  department      String
  owner           String
  reviewDate      DateTime?
  approvalDate    DateTime?
  approvedBy      String?
  documentUrl     String?
  aiReviewed      Boolean  @default(false)
  aiConfidence    Float    @default(0.0)
  jurisdiction    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, department])
  @@index([owner])
  @@index([category, status])
  @@index([jurisdiction, status])
}

model LaborLawCompliance {
  id              String   @id @default(cuid())
  requirement     String
  category        String   @default("General")
  authority       String   @default("MOHRE")
  complianceStatus String  @default("PENDING")
  dueDate         DateTime?
  assignedTo      String?
  details         String?
  quotaType       String?
  currentCount    Int      @default(0)
  requiredCount   Int      @default(0)
  lastVerified    DateTime?
  jurisdiction    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([jurisdiction, complianceStatus])
}

model LegalCase {
  id              String   @id @default(cuid())
  caseNumber      String   @unique
  title           String
  caseType        String
  status          String   @default("open")
  priority        String   @default("normal")
  assignedCounsel String?
  department      String?
  description     String?
  filingDate      DateTime?
  nextHearing     DateTime?
  resolutionDate  DateTime?
  jurisdiction    String
  aiSummary       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([jurisdiction, status])
  @@index([jurisdiction, createdAt])
}

model TrainingCourse {
  id              String   @id @default(cuid())
  title           String
  category        String
  provider        String?
  durationHours   Float    @default(0.0)
  isMandatory     Boolean  @default(false)
  targetAudience  String?
  certification   Boolean  @default(false)
  validForMonths  Int      @default(12)
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TrainingEnrollment {
  id                  String    @id @default(cuid())
  courseId            String
  userId              String
  userName            String
  department          String
  status              String    @default("enrolled")
  enrolledAt          DateTime  @default(now())
  completedAt         DateTime?
  expiryDate          DateTime?
  score               Float?
  certificateUrl      String?

  // Training Effectiveness Measurement Fields
  preAssessmentScore  Float?               // Pre-training assessment score (0-100)
  postAssessmentScore Float?               // Post-training assessment score (0-100)
  knowledgeGain       Float?               // Calculated: post - pre
  assessmentMethod    String?              // "quiz", "practical", "scenario", "peer_review"
  assessmentDate      DateTime?            // Date post-assessment was completed
  effectivenessRating String?              // "excellent", "good", "satisfactory", "needs_improvement"

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  assessments         TrainingAssessment[]
}

model TrainingAssessment {
  id               String   @id @default(cuid())
  enrollmentId     String   // FK to TrainingEnrollment
  assessmentType   String   // "pre" or "post"
  score            Float    // Raw score achieved
  maxScore         Float    @default(100)
  percentage       Float    // score / maxScore * 100
  passed           Boolean  @default(false)
  passingThreshold Float    @default(70)
  questions        String   // JSON: array of { question, answer, correct, score }
  timeTakenMinutes Int?
  completedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  enrollment       TrainingEnrollment @relation(fields: [enrollmentId], references: [id])
}

model ComplianceAudit {
  id              String   @id @default(cuid())
  auditNumber     String   @unique
  title           String
  auditType       String   @default("internal")
  status          String   @default("scheduled")
  scheduledDate   DateTime?
  completedDate   DateTime?
  leadAuditor     String?
  scope           String?
  findings        String?
  remediationStatus String @default("not_started")
  remediationDueDate DateTime?
  riskLevel       String   @default("medium")
  jurisdiction    String
  department      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([jurisdiction, status])
  @@index([jurisdiction, createdAt])
}

// ─── Phase 3: Advanced Compliance Workflows ──────────────────────────────────

model AdverseMediaSession {
  id                String   @id @default(cuid())
  subjectType       String   // "INDIVIDUAL" or "ENTITY"
  subjectName       String
  aka               String?
  nationality       String?
  searchConfig      String   // JSON string of keywords/filters
  results           String   // JSON string of logged results
  decision          String?  // "CLEAR", "POTENTIAL_MATCH", "FALSE_POSITIVE", "CONFIRMED_MATCH"
  rationale         String?
  esgRiskTags       String   @default("[]")  // JSON array of ESG risk tags
  esgRiskScore      Int      @default(0)     // 0-100 ESG risk score
  createdAt         DateTime @default(now())
  createdBy         String
}

model CorporateKYC {
  id                String   @id @default(cuid())
  legalName         String
  tradeLicenseNo    String
  trn               String?
  legalForm         String   // e.g., "LLC", "PJSC", "Free Zone"
  uboIdentified     Boolean  @default(false)
  uboDetails        String?  // JSON of UBOs (>=25% ownership)
  pepInManagement   Boolean  @default(false)
  riskScore         Int      @default(0) // 0-100
  riskRating        String   // "LOW", "MEDIUM", "HIGH"
  status            String   @default("DRAFT") // DRAFT, PENDING_MAKER_CHECKER, APPROVED, REJECTED
  jurisdiction      String
  createdAt         DateTime @default(now())

  @@index([status, riskRating])
  @@index([legalName])
  @@index([createdAt])
  @@index([jurisdiction, status])
}

model IndividualKYC {
  id                String   @id @default(cuid())
  fullName          String
  emiratesId        String?
  passportNo        String
  nationality       String
  isPep             Boolean  @default(false)
  riskRating        String   // "STANDARD", "HIGH"
  eddRequired       Boolean  @default(false)
  status            String   @default("DRAFT")
  jurisdiction      String
  createdAt         DateTime @default(now())

  @@index([status])
  @@index([nationality])
  @@index([jurisdiction, status])
}

model GoAMLFiling {
  id                String   @id @default(cuid())
  reportType        String   // "STR", "SAR", "CTR", "IFT", "PNMR"
  referenceNumber   String   @unique
  subjectName       String
  amountAED         Float?
  filingStatus      String   // "DRAFT", "PENDING_APPROVAL", "SUBMITTED_TO_FIU", "ACKNOWLEDGED"
  xmlPayload        String   // Stored XML string
  fiuAcknowledgementId String?
  jurisdiction      String
  createdAt         DateTime @default(now())
  submittedAt       DateTime?

  @@index([filingStatus, createdAt])
  @@index([reportType, filingStatus])
  @@index([createdAt])
  @@index([jurisdiction, filingStatus, createdAt])
}

model MakerCheckerLog {
  id                String   @id @default(cuid())
  operationType     String   // e.g., "KYC_HIGH_RISK_APPROVAL", "GOAML_SUBMIT"
  entityId          String
  entityType        String   // e.g., "CorporateKYC", "GoAMLFiling"
  makerId           String
  makerName         String
  checkerId         String?
  checkerName       String?
  status            String   // "PENDING", "APPROVED", "REJECTED", "EXPIRED"
  expiryTime        DateTime
  payloadSnapshot   String   // JSON of what is being approved
  jurisdiction      String
  createdAt         DateTime @default(now())
  reviewedAt        DateTime?

  @@index([status, expiryTime])
  @@index([entityType, entityId])
  @@index([makerId, status])
  @@index([jurisdiction, status])
}

// ─── Phase 4: On-Premise AI Agent & Quarterly CBUAE Reporting ────────────────

model AIChatSession {
  id            String   @id @default(cuid())
  userId        String
  contextModule String   // e.g., "goAML", "Nafis", "Insurance", "General"
  createdAt     DateTime @default(now())
  messages      AIChatMessage[]
}

model AIEngineConfig {
  id                 String   @id @default(cuid())
  provider           String   @default("z-ai")   // "z-ai", "openai", "anthropic"
  apiKey             String?                       // Encrypted at rest; NEVER returned in plaintext
  defaultModel       String   @default("default")
  temperature        Float    @default(0.3)
  maxTokens          Int      @default(2048)
  topP               Float    @default(0.9)
  frequencyPenalty   Float    @default(0.0)
  presencePenalty    Float    @default(0.0)
  monthlyTokenQuota  Int      @default(500000)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AIChatMessage {
  id          String   @id @default(cuid())
  sessionId   String
  session     AIChatSession @relation(fields: [sessionId], references: [id])
  role        String   // "user" or "assistant"
  content     String
  modelUsed   String?  // e.g., "llama3:8b", "qwen2.5:14b"
  latencyMs   Int?
  createdAt   DateTime @default(now())
}

model QuarterlyReport {
  id                String   @id @default(cuid())
  quarter           String   // e.g., "Q3-2024"
  year              Int
  entityName        String
  totalPolicies     Int
  totalPremiumAED   Float
  activePolicies    Int
  cancellationRate  Float
  status            String   // "PROCESSING", "VALIDATED", "READY", "SUBMITTED"
  cbuaeSubmissionId String?
  createdAt         DateTime @default(now())
  records           InsuranceRecord[]
}

model InsuranceRecord {
  id                String   @id @default(cuid())
  policyNumber      String   @unique
  clientName        String   // Will be masked in CBUAE view
  emirate           String
  productType       String
  premiumAED        Float    // Will be masked in CBUAE view
  amlStatus         String   // "CLEARED", "FLAGGED"
  reportId          String?
  report            QuarterlyReport? @relation(fields: [reportId], references: [id])
}

// ─── Phase 5: Regulatory Critical Enhancement Models (FDL 10/2025 / CR 134/2025) ──

/// Compliance alerts for SAR deadlines, regulatory deadlines, MLRO escalations
/// Fail-closed: All MLRO deadline alerts immutably logged per C5 requirement
model ComplianceAlert {
  id              String   @id @default(cuid())
  alertType       String   // "SAR_DEADLINE", "REGULATORY_DEADLINE", "MLRO_ESCALATION", "KYC_REVIEW_OVERDUE", "TRAINING_OVERDUE", "SANCTIONS_SCREENING_DUE", "POLICY_REVIEW_DUE"
  severity        String   @default("high")  // "low", "medium", "high", "critical"
  status          String   @default("active") // "active", "acknowledged", "resolved", "expired"
  title           String
  description     String
  sourceModule    String   // Module that triggered the alert
  sourceEntityId  String?  // ID of the related entity
  sourceEntityType String? // "AMLAlert", "GoAMLFiling", "CorporateKYC", etc.
  dueDate         DateTime // Deadline for the alert
  assignedToId    String?  // User responsible
  acknowledgedAt  DateTime?
  acknowledgedBy  String?
  resolvedAt      DateTime?
  resolutionNote  String?
  isImmutable     Boolean  @default(true) // Cannot be deleted once created
  sha256Hash      String?  // Integrity verification
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([alertType, status])
  @@index([severity, status])
  @@index([dueDate, status])
  @@index([sourceEntityId, sourceEntityType])
}

/// Sanctions screening events with fuzzy match tracking
model SanctionsScreening {
  id              String   @id @default(cuid())
  screeningId     String   @unique // Unique screening event ID
  entityType      String   // "INDIVIDUAL", "ENTITY"
  primaryName     String
  aliases         String?  // JSON array of aliases
  identifiers     String?  // JSON: emiratesId, passportNo, dob
  status          String   @default("CLEAR") // "CLEAR", "POTENTIAL_MATCH", "CONFIRMED_MATCH", "ERROR"
  highestScore    Int      @default(0) // 0-100 fuzzy match score
  matches         String?  // JSON array of match details
  screeningLists  String?  // JSON: which lists were screened
  idempotencyKey  String?  // Prevents duplicate screening
  screenedById    String?  // User who initiated
  failClosed      Boolean  @default(true) // If screening fails, default to blocking
  errorMessage    String?  // If screening failed
  jurisdiction    String
  screeningHash   String?  // SHA-256 integrity hash (Fix 5 + Addendum E)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, highestScore])
  @@index([primaryName])
  @@index([createdAt])
  @@index([jurisdiction, status, createdAt])
  @@index([jurisdiction, createdAt])
}

/// SAR Case tracking with 30-day FDL 10/2025 deadline enforcement
model SARCase {
  id                String   @id @default(cuid())
  caseNumber        String   @unique
  alertId           String?  // Link to originating AML alert
  filingDeadline    DateTime // Must be <= 30 days from trigger date (FDL 10/2025 Art. 8)
  triggerDate       DateTime // Date the SAR obligation was triggered
  daysRemaining     Int      @default(30)
  status            String   @default("DRAFT") // "DRAFT", "PENDING_REVIEW", "REQUIRES_REVISION", "APPROVED_FOR_FILING", "SUBMITTED_TO_FIU", "REJECTED_BY_FIU"
  narrative         String?  // Long text field for SAR narrative
  goamlXmlPath      String?  // Path to generated XML
  tippingOffWarning Boolean  @default(true) // Mandatory CBUAE requirement (FDL 10/2025 Art. 12)
  tippingOffAcknowledgedAt DateTime?
  subjectName       String
  subjectType       String   @default("INDIVIDUAL") // "INDIVIDUAL", "ENTITY"
  jurisdiction      String
  riskLevel         String   @default("high")
  createdById       String?
  reviewedById      String?
  submittedById     String?
  submittedAt       DateTime?
  rejectionReason   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status, filingDeadline])
  @@index([alertId])
  @@index([filingDeadline])
  @@index([jurisdiction, status, filingDeadline])
}

/// Compliance calendar events with cross-module integration
model CalendarEvent {
  id              String   @id @default(cuid())
  title           String
  description     String?
  eventType       String   // "regulatory", "audit", "training", "policy", "aml", "kyc_review", "sar_deadline", "sanctions_screening"
  eventDate       DateTime
  endDate         DateTime?
  priority        String   @default("normal") // "low", "normal", "high", "urgent"
  jurisdiction    String
  status          String   @default("upcoming") // "upcoming", "in_progress", "completed", "overdue", "cancelled"
  sourceModule    String?  // Module that created this event
  sourceEntityId  String?  // ID of related entity
  isRecurring     Boolean  @default(false)
  recurringPattern String? // "daily", "weekly", "monthly", "quarterly", "annually"
  assignedToId    String?
  location        String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([eventDate, status])
  @@index([eventType, status])
  @@index([jurisdiction, eventDate])
}

/// Policy attestation tracking per CR 134/2025
model PolicyAttestation {
