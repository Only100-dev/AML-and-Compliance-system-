  @@index([createdAt])
}

/// QA stratified random sampling — risk-based quality assurance case selection
model QASample {
  id              String   @id @default(cuid())
  sampleBatchId   String   // Groups samples from the same sampling run
  caseId          String
  caseType        String   // alert, kyc, sar, tfs
  riskLevel       String   // low, medium, high, critical
  assignedOfficer String?
  sampledAt       DateTime @default(now())
  reviewStatus    String   @default("PENDING")  // PENDING, REVIEWED, DEFICIENT
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([sampleBatchId])
  @@index([caseType])
  @@index([riskLevel])
  @@index([reviewStatus])
}

/// QA finding with immutable scoring — audit-grade quality review results
model QAReview {
  id              String   @id @default(cuid())
  sampleId        String
  reviewerId      String
  reviewerName    String?
  accuracyScore   Int      @default(0)  // 0-100
  timelinessScore Int      @default(0)  // 0-100
  completenessScore Int    @default(0)  // 0-100
  findings        String?  // JSON: detailed findings
  isDeficient     Boolean  @default(false)
  sha256Hash      String?
  createdAt       DateTime @default(now())

  @@index([sampleId])
  @@index([reviewerId])
  @@index([isDeficient])
  @@index([createdAt])
}

/// Dept Head circular acknowledgment with SLA tracking — 5-day ack / 10-day action plan
model DepartmentAcknowledgment {
  id                String    @id @default(cuid())
  circularId        String
  departmentName    String
  acknowledgedById  String
  acknowledgedByName String?
  acknowledgedAt    DateTime?
  actionPlan        String?
  actionPlanDueDate DateTime?
  actionPlanSubmittedAt DateTime?
  slaDeadlineAck    DateTime?  // 5 business days from circular
  slaDeadlineAction DateTime?  // 10 business days from circular
  slaStatus         String    @default("PENDING_ACK")  // PENDING_ACK, ACKNOWLEDGED, ACTION_PLAN_SUBMITTED, OVERDUE_ACK, OVERDUE_ACTION
  escalatedToCCO    Boolean   @default(false)
  escalatedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([circularId])
  @@index([acknowledgedById])
  @@index([slaStatus])
  @@index([escalatedToCCO])
}

/// CAP Kanban board — corrective action tracking from audits, regulatory, and QA findings
model CorrectiveActionPlan {
  id                String   @id @default(cuid())
  title             String
  description       String
  sourceType        String   // AUDIT_FINDING, REGULATORY_TRACKER, QA_FINDING
  sourceReferenceId String?
  priority          String   @default("medium")  // low, medium, high, critical
  state             String   @default("TODO")  // TODO, IN_PROGRESS, REMEDIATED, AUDIT_VERIFIED
  assignedToId      String?
  assignedToName    String?
  dueDate           DateTime?
  remediatedAt      DateTime?
  auditVerifiedAt   DateTime?
  auditVerifiedById String?
  auditVerifiedByName String?
  verificationNotes String?
  sha256Hash        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([state])
  @@index([priority])
  @@index([sourceType])
  @@index([assignedToId])
  @@index([dueDate])
}

/// Source of Wealth / Source of Funds records — CBUAE Insurance AML high-risk product due diligence
model SoWSoFRecord {
  id                    String   @id @default(cuid())
  caseId                String   // Link to ComplianceCase
  sowDescription        String?  // Source of Wealth description
  sofDescription        String?  // Source of Funds description
  documentaryEvidence   Boolean  @default(false) // Whether documentary evidence has been provided
  productRiskScore      Int      @default(5)  // Risk score of associated product (1-10)
  isHighRisk            Boolean  @default(false)  // Derived: productRiskScore >= 7
  status                String   @default("PENDING")  // PENDING, APPROVED, REJECTED, UNDER_REVIEW
  approvedById          String?
  approvedAt            DateTime?
  reviewNotes           String?
  createdBy             String?
  sha256Hash            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@index([isHighRisk])
  @@index([createdAt])
}

/// P2 (Complaint Management) — minimal forward-compatible scaffold for CBUAE
/// complaint-handling SLA tracking. The schema was signed off in P2 but the
/// model was not yet persisted; this minimal version unblocks the P3 Step 2
/// Predictive Risk Scoring engine (BREACHED Complaint SLA factor) and can be
/// extended in a later sprint with full workflow fields.
model Complaint {
  id                    String   @id @default(cuid())
  complaintNumber       String   @unique
  subject               String
  description           String
  complaintType         String   // e.g. CUSTOMER, REGULATORY, INTERNAL, THIRD_PARTY
  priority              String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status                String   @default("NEW") // NEW, ACKNOWLEDGED, INVESTIGATING, RESOLVED, REJECTED, CLOSED
  departmentId          String?  // department the complaint is assigned to
  // CBUAE SLA fields
  slaDeadlineAck        DateTime?   // 5 business days from creation
  slaDeadlineResolution DateTime?   // 30 business days from creation
  slaStatus             String   @default("WITHIN_SLA") // WITHIN_SLA, APPROACHING_BREACH, BREACHED, N/A
  acknowledgedAt        DateTime?
  resolvedAt            DateTime?
  acknowledgedById      String?
  resolvedById          String?
  rejectionReason       String?
  // Relational links (optional, nullable for flexibility)
  policyId              String?
  claimId               String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([departmentId])
  @@index([status])
  @@index([slaStatus])
  @@index([createdAt])        // v7.3.0: ORDER BY createdAt DESC (list endpoint)
  @@index([status, createdAt]) // v7.3.0: filter + sort composite (list endpoint)
}

/// P3 Step 2 — Predictive Risk Scoring. One row per department, refreshed by
/// the nightly `calculate-department-risk` cron job. The `factors` JSON holds
/// the per-factor breakdown (label / points / count / detail) so the UI can
/// render a transparent heatmap drill-down.
model DepartmentRiskScore {
  id            String   @id @default(cuid())
  departmentId  String   @unique
  score         Int
  calculatedAt  DateTime @default(now())
  factors       Json     // breakdown of why the score is what it is
}

/// v7.3.0 — Unified My Tasks inbox. One row per actionable work item across
/// the platform (ComplianceAlerts, Complaints, CAPs, SARs, Maker-Checker
/// requests). Surfaced via GET /api/tasks/my-tasks. Backfilled from existing
/// records by scripts/backfill-universal-tasks.mjs; new records are created
/// on-demand by the relevant module APIs.
model UniversalTask {
  id              String   @id @default(cuid())
  taskType        String   // ALERT | COMPLAINT | CAP | SAR | MAKER_CHECKER
  sourceId        String   // FK to the source record (ComplianceAlert.id, Complaint.id, etc.)
  sourceEntityType String  // 'ComplianceAlert' | 'Complaint' | 'CorrectiveActionPlan' | 'SARCase' | 'MakerCheckerLog'
  title           String
  description     String?
  assignedToId    String?  // null = unassigned/pool
  assignedToName  String?
  priority        String   @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  status          String   @default("OPEN") // OPEN | IN_PROGRESS | DONE | CANCELLED
  dueDate         DateTime?
  sourceModule    String   // COMPLIANCE_ALERTS | COMPLAINTS | CAP | SAR | MAKER_CHECKER
  isImmutable     Boolean  @default(false) // if true, cannot be cancelled from the inbox
  sha256Hash      String?  // tamper-evidence (chain to source.sha256Hash)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([assignedToId, status, dueDate])
  @@index([status, createdAt])
  @@index([taskType, status])
  @@unique([taskType, sourceId]) // one UniversalTask per source record
}

/// Policy & Procedure Management — version-controlled content body (Section 10.6)
/// One row per version of a policy. The Policy model holds metadata;
/// PolicyVersion holds the actual text content with section structure.
model PolicyVersion {
  id              String   @id @default(cuid())
  policyId        String   // FK to Policy.id
  version         String   // e.g. "1.0", "1.1", "2.0"
  title           String
  contentBody     String   // full markdown/text content of the policy
  sections        String   // JSON array of {sectionNumber, heading, content}
  changeLog       String?  // what changed in this version
  authoredBy      String
  reviewedBy      String?
  approvedBy      String?
  status          String   @default("draft") // draft | under_review | approved | published | superseded
  effectiveDate   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([policyId, version])
  @@index([status])
}

/// Normalized insurance department with compliance ownership (Section 10.6)
model Department {
  id                String   @id @default(cuid())
  name              String   @unique // Underwriting, Claims, Brokerage, Finance, IT, Compliance, Legal, HR
  displayName       String
  headUserId        String?  // FK to User.id (the Dept Head)
  headName          String?
  complianceScope   String   // "direct" | "indirect" AML/CFT involvement
  description       String?
  policyCount       Int      @default(0)
  activeFindings    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

/// Structured cross-reference: regulatory obligation → internal policy section
/// Replaces the unstructured GapAnalysis.missingClauses text blob.
model ObligationPolicyMapping {
  id                String   @id @default(cuid())
  obligationId      String   // FK to ExtractedObligation.id
  circularId        String   // FK to RegulatoryCircular.id (denormalized for query efficiency)
  policyId          String?  // FK to Policy.id (null if no matching policy = MISSING)
  policySection     String?  // e.g. "Section 4.2"
  coverageStatus    String   @default("MISSING") // COVERED | PARTIAL | MISSING
  gapDescription    String?  // what's missing
  remediationAction String?  // recommended fix
  owner             String?  // responsible role/person
  dueDate           DateTime?
  status            String   @default("OPEN") // OPEN | IN_PROGRESS | REMEDIATED | ACCEPTED_RISK
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([obligationId])
  @@index([circularId])
  @@index([policyId])
  @@index([coverageStatus])
}

// ─────────────────────────────────────────────────────────────────────────────
// Intelligence Engine — Phase 1-5 Models
// AI-Powered Regulatory Intelligence Search with Dual-Master-Brain,
// Action Center, Alerts/Watchlists, Agent Management & Executive Dashboard
// ─────────────────────────────────────────────────────────────────────────────

/// Intelligence items represent regulatory updates, enforcement actions,
/// guidance notes, and other intelligence from GCC regulators.
model IntelligenceItem {
  id              String   @id @default(cuid())
  title           String
  summary         String
  sourceName      String   // e.g. "SAMA", "CBUAE", "CBB"
  sourceUrl       String?
  category        String   // REGULATORY | ENFORCEMENT | GUIDANCE | ADVISORY | INDUSTRY
  riskScore       Int      @default(0)   // 0-100
  riskLevel       String   @default("LOW") // LOW | MEDIUM | HIGH | CRITICAL
  credibility     String   @default("VERIFIED") // UNVERIFIED | PARTIALLY_VERIFIED | VERIFIED | OFFICIAL
  jurisdictionId  String   // FK to GCC jurisdiction code: AE, SA, BH, QA, OM, KW
  regulator       String?  // e.g. "SAMA", "CBUAE", "CBB", "QCB"
  publishedDate   DateTime?
  aiSummary       String?  // GLM-5.2 generated summary
  aiVerified      Boolean  @default(false) // Qwen3.7-Plus verification
  aiVerificationNotes String?
  sourceLineage   String?  // JSON array of source chain
  chainOfThought  String?  // JSON: AI reasoning trace
  tags            String?  // JSON array of tags
  status          String   @default("NEW") // NEW | REVIEWED | UNDER_ANALYSIS | ACTIONED | ARCHIVED
  assignedToId    String?  // FK to User.id
  assignedToName  String?
  dueDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  entities        IntelligenceEntity[]
  policyMappings  IntelligencePolicyMapping[]
  watchlistEntries WatchlistItem[]
  actions         IntelligenceAction[]

  @@index([jurisdictionId])
  @@index([category])
  @@index([riskLevel])
  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

/// Named entities extracted from intelligence items (people, organizations, etc.)
model IntelligenceEntity {
  id                String   @id @default(cuid())
  itemId            String   // FK to IntelligenceItem.id
  name              String
  type              String   // PERSON | ORGANIZATION | REGULATOR | FINANCIAL_INSTITUTION | COUNTRY
  role              String?  // e.g. "Subject", "Issuer", "Counterparty"
  riskContribution  Int      @default(0) // 0-100
  metadata          String?  // JSON: additional entity data
  createdAt         DateTime @default(now())

  intelligenceItem  IntelligenceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([type])
  @@index([name])
}

/// Maps external regulatory intelligence to internal policies
model IntelligencePolicyMapping {
  id                String   @id @default(cuid())
  itemId            String   // FK to IntelligenceItem.id
  policyId          String?  // FK to Policy.id (null = no mapping = GAP)
  policyNumber      String?
  coverageStatus    String   @default("UNMAPPED") // UNMAPPED | PARTIAL | COVERED | GAP
  impactAssessment  String?  // AI-generated impact summary
  remediationAction String?
  owner             String?
  dueDate           DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  intelligenceItem  IntelligenceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([policyId])
  @@index([coverageStatus])
}

/// Saved searches for re-running intelligence queries
model SavedSearch {
  id            String   @id @default(cuid())
  userId        String   // FK to User.id
  name          String
  query         String   // search terms
  filters       String?  // JSON: {jurisdiction, category, riskLevel, credibility, dateRange}
  resultCount   Int      @default(0)
  lastRunAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

/// Alert rules created from saved searches
model AlertRule {
  id            String   @id @default(cuid())
  userId        String   // FK to User.id
  name          String
  query         String   // search terms
  filters       String?  // JSON: same as SavedSearch
  frequency     String   @default("DAILY") // IMMEDIATE | DAILY | WEEKLY
  isActive      Boolean  @default(true)
  lastTriggered DateTime?
  triggerCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([frequency])
}

/// Watchlist items — pinned IntelligenceItems or TrendSignals per user
model WatchlistItem {
  id            String   @id @default(cuid())
  userId        String   // FK to User.id
  itemType      String   // INTELLIGENCE_ITEM | TREND_SIGNAL
  itemId        String   // FK to IntelligenceItem.id or TrendSignal.id
  notes         String?
  pinnedAt      DateTime @default(now())

  intelligenceItem IntelligenceItem? @relation(fields: [itemId], references: [id], onDelete: Cascade)
  trendSignal      TrendSignal?      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType, itemId])
  @@index([userId])
  @@index([itemType])
}

/// AI-detected trend signals from autonomous scanner
model TrendSignal {
  id              String   @id @default(cuid())
  title           String
  description     String
  trendType       String   // EMERGING_REGULATION | ENFORCEMENT_TREND | INDUSTRY_SHIFT | CROSS_JURISDICTION | RISK_ESCALATION
  severity        String   @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  confidence      Int      @default(0) // 0-100
  jurisdictions   String?  // JSON array: ["AE","SA","BH"]
  sources         String?  // JSON array: source references
  chainOfThought  String?  // JSON: AI reasoning trace
  aiModel         String   @default("GLM-5.2") // which AI generated this
  verifiedBy      String?  // AI model that verified (Qwen3.7-Plus)
  verificationStatus String @default("PENDING") // PENDING | VERIFIED | DISPUTED
  validFrom       DateTime @default(now())
  validTo         DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  watchlistItems WatchlistItem[]

  @@index([trendType])
  @@index([severity])
  @@index([isActive])
  @@index([createdAt])
}

/// Intelligence actions — task assignments, Maker-Checker routing, status tracking
model IntelligenceAction {
  id              String   @id @default(cuid())
  itemId          String   // FK to IntelligenceItem.id
  actionType      String   // ASSIGN | ROUTE_TO_POLICY_OWNER | STATUS_CHANGE | ADD_NOTE | ESCALATE
  assignedToId    String?  // FK to User.id
  assignedToName  String?
  assignedBy      String
  assignedByRole  String
  statusFrom      String?  // previous status
  statusTo        String?  // new status
  notes           String?
  dueDate         DateTime?
  policyMappingId String?  // FK to IntelligencePolicyMapping.id (for ROUTE_TO_POLICY_OWNER)
  makerCheckerId  String?  // FK to MakerCheckerLog.id (if routed to Maker-Checker)
  aiImpactSummary String?  // AI-generated impact summary for routing
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  intelligenceItem IntelligenceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([assignedToId])
  @@index([actionType])
  @@index([createdAt])
}

/// Autonomous Agent scan logs
model AgentScanLog {
  id              String   @id @default(cuid())
  scanType        String   // SCHEDULED | MANUAL | TRIGGERED
  jurisdictionId  String?  // null = all jurisdictions
  topic           String?  // specific topic searched
  sourcesQueried  String?  // JSON array of sources queried
  sourcesIgnored  String?  // JSON array of sources filtered out
  itemsFound      Int      @default(0)
  itemsIngested   Int      @default(0)
  trendSignalsGenerated Int @default(0)
  confidenceThreshold Int  @default(50) // minimum confidence to include
  riskThreshold   Int      @default(50) // minimum risk score to include
  status          String   @default("RUNNING") // RUNNING | COMPLETED | FAILED | CANCELLED
  duration        Int?     // milliseconds
  error           String?  // error message if failed
  triggeredBy     String   // userId or "system"
  aiModel         String   @default("GLM-5.2")
  startedAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([jurisdictionId])
  @@index([status])
  @@index([startedAt])
  @@index([scanType])
}

/// Agent configuration (tuning parameters)
model AgentConfig {
  id                    String   @id @default(cuid())
  isScannerActive       Boolean  @default(true)
  scanIntervalMinutes   Int      @default(60)
  confidenceThreshold   Int      @default(50)
  riskThreshold         Int      @default(70) // only alert on risk > 70
  maxItemsPerScan       Int      @default(50)
  enabledJurisdictions  String?  // JSON array: ["AE","SA","BH","QA","OM","KW"]
  enabledSources        String?  // JSON array of enabled source names
  updatedBy             String?  // userId
  updatedAt             DateTime @updatedAt
}

/// Export audit log (WORM compliance)
model IntelligenceExport {
  id            String   @id @default(cuid())
  userId        String
  userName      String
  userRole      String
  exportType    String   // PDF | CSV | JSON
  exportScope   String   // SEARCH_RESULTS | WATCHLIST | EXECUTIVE_BRIEFING | TREND_REPORT
  recordCount   Int      @default(0)
  filters       String?  // JSON: applied filters
  jurisdiction  String?  // jurisdiction scope
  fileName      String?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([exportType])
  @@index([createdAt])
}
