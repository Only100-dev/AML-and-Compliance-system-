/// Terrorist Financing Sanctions freeze/unfreeze actions per CBUAE requirements
model TFSAction {
  id                    String    @id @default(cuid())
  tfsReferenceNumber    String    @unique
  entityName            String
  entityType            String    // INDIVIDUAL, ENTITY
  sanctionsList         String    // UN_SC, EU, UAE_LOCAL, OFAC, OTHER
  matchScore            Int       @default(0)
  matchDetails          String?
  status                String    @default("AUTO_FROZEN")  // AUTO_FROZEN, CONFIRMED, UNFROZEN, FALSE_POSITIVE
  freezeOrderDate       DateTime  @default(now())
  unfreezeRequestDate   DateTime?
  unfreezeApprovalDate  DateTime?
  unfreezeAuthority     String?
  fiuReportId           String?
  tippingOffWarning     Boolean   @default(true)
  sha256Hash            String?
  jurisdiction          String
  riskLevel             String    @default("critical")
  confirmedById         String?
  confirmedAt           DateTime?

  // ── Traceability Foreign Keys (Pre-UAT Polish Fix #1) ──────────────────────
  // An auditor reviewing a frozen asset must be able to trace it directly
  // back to the specific Customer, Policy, and Case ID.
  // Ref: FDL 10/2025 Art. 11 (Record-Keeping); CBUAE Notice 3551/2021 S3.3
  customerId            String?   // FK → User.id (policyholder / entity owner)
  policyId              String?   // FK → Policy.id (insurance policy under freeze)
  caseId                String?   // FK → ComplianceCase.id (linked investigation case)

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status])
  @@index([entityName])
  @@index([sanctionsList])
  @@index([freezeOrderDate])
  @@index([tfsReferenceNumber])
  @@index([customerId])
  @@index([policyId])
  @@index([caseId])
}

